<?xml version="1.0" encoding="utf-8"?>

<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.focusanalyzer">

    <application
        android:allowBackup="true"
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:theme="@style/Theme.FocusAnalyzer">

        <!-- LAUNCH SCREEN -->
        <activity
            android:name=".ui.timer.TimerActivity"
            android:exported="true">

            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>

        </activity>

        <!-- OTHER SCREENS -->
        <activity android:name=".ui.history.HistoryActivity"/>
        <activity android:name=".ui.insights.InsightsActivity"/>

    </application>

</manifest>